rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // settings 컬렉션 (옵션 설정)
    match /settings/{document=**} {
      allow read, write: if true;
    }
    
    // data 컬렉션 (조회 데이터)
    match /data/{document=**} {
      allow read, write: if true;
    }
    
    // inputSheet 컬렉션 (실시간 입력 시트)
    match /inputSheet/{document=**} {
      allow read, write: if true;
    }
  }
}

